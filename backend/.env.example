# Server
PORT=5000
NODE_ENV=development

# PostgreSQL / Supabase
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:5432/postgres

# JWT
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:5173

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
